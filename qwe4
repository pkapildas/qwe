import re

# 1. Extract BHK/Size numeric values from strings (e.g. '2 BHK' -> 2, '4 Bedroom' -> 4)
def extract_bhk_size(df, size_col):
    # Extract the first sequence of digits found in the size column
    df[size_col + '_num'] = df[size_col].astype(str).str.extract(r'(\d+)').astype(float)
    print(f"Extracted numeric BHK/Size into '{size_col}_num'")
    return df

# 2. Parse range values and mixed text in square feet (e.g. '2100 - 2850' -> 2475.0)
def parse_sqft_range(val):
    if isinstance(val, str):
        # Case A: range string with '-'
        if '-' in val:
            parts = val.split('-')
            try:
                return (float(parts[0].strip()) + float(parts[1].strip())) / 2
            except:
                return None
        # Case B: standard float or integer represented as string
        try:
            return float(val.strip())
        except:
            # Case C: contains numbers alongside letters (e.g. '1056 Sq. Yards')
            nums = re.findall(r'\d+\.?\d*', val)
            if nums:
                return float(nums[0])
            return None
    return float(val)

def clean_total_sqft(df, sqft_col):
    df[sqft_col + '_clean'] = df[sqft_col].apply(parse_sqft_range)
    print(f"Cleaned ranges/text in '{sqft_col}' column into '{sqft_col}_clean'")
    return df

# 3. Extract Year, Month, Day, Hour from Datetime column (Step 9)
def extract_datetime_components(df, datetime_col):
    df_clean = df.copy()
    # Cast to datetime (errors='coerce' turns non-dates into NaT)
    df_clean[datetime_col] = pd.to_datetime(df_clean[datetime_col], errors='coerce')
    
    df_clean[datetime_col + '_year'] = df_clean[datetime_col].dt.year
    df_clean[datetime_col + '_month'] = df_clean[datetime_col].dt.month
    df_clean[datetime_col + '_day'] = df_clean[datetime_col].dt.day
    df_clean[datetime_col + '_hour'] = df_clean[datetime_col].dt.hour
    
    print(f"Extracted Year, Month, Day, Hour from '{datetime_col}'")
    return df_clean

# 4. Map numerical codes to text labels (Step 10)
def map_numeric_codes(df, col, mapping_dict):
