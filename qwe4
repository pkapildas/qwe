# 4. Box-Cox & Yeo-Johnson Transformations for Normality and Skewness Reduction
from scipy import stats
from sklearn.preprocessing import PowerTransformer

def apply_box_cox(df, col):
    """
    Applies the Box-Cox transformation to a feature.
    Note: Box-Cox requires strictly positive values (> 0).
    If the feature contains non-positive values, it automatically shifts them.
    """
    min_val = df[col].min()
    shift = 0
    if min_val <= 0:
        shift = abs(min_val) + 1
        series_to_transform = df[col] + shift
        print(f"Column '{col}' has non-positive values. Shifted by {shift} before Box-Cox.")
    else:
        series_to_transform = df[col]
        
    transformed_data, fitted_lambda = stats.boxcox(series_to_transform)
    df[col + '_boxcox'] = transformed_data
    print(f"Applied Box-Cox on '{col}': lambda = {fitted_lambda:.4f} (Shift: {shift})")
    return df, fitted_lambda, shift

def apply_yeo_johnson(df, col):
    """
    Applies the Yeo-Johnson transformation.
    Unlike Box-Cox, Yeo-Johnson supports zero and negative values natively.
    """
    pt = PowerTransformer(method='yeo-johnson')
    df[col + '_yj'] = pt.fit_transform(df[[col]])
    print(f"Applied Yeo-Johnson transformation on '{col}'")
    return df, pt


