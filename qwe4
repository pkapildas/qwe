# 2. Custom Forward Feature Selection (p-value based using statsmodels)
def custom_forward_selection(X, y, significance_level=0.05):
    """
    Performs Forward Feature Selection based on OLS p-values iteratively.
    Adds one feature at a time that has the lowest p-value below the significance level.
    """
    initial_features = X.columns.tolist()
    best_features = []
    iteration = 1
    
    while len(initial_features) > 0:
        remaining_features = list(set(initial_features) - set(best_features))
        new_pval = pd.Series(index=remaining_features, dtype=float)
        
        for new_column in remaining_features:
            # Fit model with current best features plus the candidate feature
            features_to_test = best_features + [new_column]
            X_with_const = sm.add_constant(X[features_to_test])
            model = sm.OLS(y, X_with_const).fit()
            new_pval[new_column] = model.pvalues[new_column]
            
        min_p_value = new_pval.min()
        best_candidate = new_pval.idxmin()
        
        if min_p_value < significance_level:
            best_features.append(best_candidate)
            print(f"Iteration {iteration}: Added '{best_candidate}' (p-value = {min_p_value:.6f})")
            iteration += 1
        else:
            print(f"Stopping Forward Selection: No remaining feature has p-value < {significance_level}")
            break
            
    print(f"Forward Selection Complete! Selected features ({len(best_features)}): {best_features}")
    return best_features


