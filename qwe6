import numpy as np
from sklearn.datasets import load_iris
from sklearn.preprocessing import StandardScaler
iris = load_iris()
X = iris.data
X = StandardScaler().fit_transform(X)
cov = np.cov(X.T)
a,b = np.linalg.eig(cov)
s = np.argsort(a)[::-1]
a = a[s]
b = b[:,s]
a_sum = np.sum(a)
a_ratio = a/a_sum
a_cum = np.cumsum(a_ratio)
k = np.argmax(a_cum>=0.95)+1
P = b[:,:k]
X_pca = X@P
print("Covariance Matrix:  ",cov)
print("Eigenvalues:  ",a)
print("Eigenvectors:  ",b)
print("Total Variance:  ",a_sum)
print("Explained Variance Ratio:  ",a_ratio)
print("Cumulative Explained Variance:  ",a_cum)
print("Number of Principal Components =",k)
print("Projection Matrix:  ",P)
print("Reduced Data:  ",X_pca)

