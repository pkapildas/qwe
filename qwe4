# 6. Outlier treatment: Drop outlier records using IQR
def drop_outliers_iqr(df, num_cols):
    clean_df = df.copy()
    for col in num_cols:
        Q1 = clean_df[col].quantile(0.25)
        Q3 = clean_df[col].quantile(0.75)
        IQR = Q3 - Q1
        lower_bound = Q1 - 1.5 * IQR
        upper_bound = Q3 + 1.5 * IQR
        
        initial_size = clean_df.shape[0]
        clean_df = clean_df[(clean_df[col] >= lower_bound) & (clean_df[col] <= upper_bound)]
        dropped = initial_size - clean_df.shape[0]
        if dropped > 0:
            print(f"Dropped {dropped} outlier rows from '{col}' (Range: [{lower_bound:.2f}, {upper_bound:.2f}])")
    print(f"Dataset shape updated: {df.shape} -> {clean_df.shape}")
    return clean_df


