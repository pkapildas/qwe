# ### E. Custom Feature Selection: Backward Elimination
# A custom function that iteratively removes features having p-value above `significance_level` (default 0.05) using statsmodels OLS. Fits models iteratively without relying on sklearn feature-selection imports.
# 

# In[43]:


def custom_backward_elimination(X, y, significance_level=0.05):
    features = list(X.columns)
    iteration = 0
    while len(features) > 0:
        X_with_const = sm.add_constant(X[features])
        model = sm.OLS(y, X_with_const).fit()
        p_values = model.pvalues.drop('const', errors='ignore')
        max_p = p_values.max()
        
        if max_p > significance_level:
            worst_feature = p_values.idxmax()
            iteration += 1
            print(f"Iteration {iteration}: Dropping '{worst_feature}' with p-value = {max_p:.4f}")
            features.remove(worst_feature)
        else:
            break
            
    print(f"\nFinal Selected Features ({len(features)}): {features}")
    return features


