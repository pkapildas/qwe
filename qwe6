# GRADIENT DESCENT
import numpy as np
import matplotlib.pyplot as plt
X = np.array([0,0.4,0.6,1])
Y = np.array([0,1,0.48,0.95])
a = 0.8 ;  b = 0.2   ;   lr = 0.1   ; iters = 2
for i in range(iters):
    Y_pred = a*X+b
    error = Y-Y_pred
    da = -2*np.sum(error*X)
    db = -2*np.sum(error)
    sse = np.sum(error**2)
    a = a-lr*da
    b = b-lr*db
    print("Iteration",i+1)
    print("a =",a)
    print("b =",b)
    print("SSE =",sse)
plt.scatter(X,Y,label="Data")
plt.plot(X,a*X+b,label="Line")
plt.xlabel("X")
plt.ylabel("Y")
plt.title("Gradient Descent")
plt.legend()
plt.grid(True)
plt.show()
