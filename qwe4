# 2. Bayesian Optimization from Scratch using Gaussian Process Regressor
from sklearn.gaussian_process import GaussianProcessRegressor
from sklearn.gaussian_process.kernels import Matern
from scipy.stats import norm

def bayesian_optimize_ridge(X_tr, y_tr, n_iter=10):
    # Objective function: minimize average 5-Fold CV RMSE
    def objective(alpha_candidate):
        alpha_val = max(1e-15, min(100.0, float(alpha_candidate)))
        model = Ridge(alpha=alpha_val, max_iter=500)
        scores = cross_val_score(model, X_tr, y_tr, cv=5, scoring='neg_root_mean_squared_error')
        return -scores.mean()

    # Initial grid points
    alphas = np.logspace(-15, 2, 5).reshape(-1, 1)
    ys = np.array([objective(a) for a in alphas])
    
    gp = GaussianProcessRegressor(kernel=Matern(nu=2.5), alpha=1e-6, normalize_y=True, random_state=42)
    
    print("Running Bayesian Optimization for Ridge Alpha...")
    for i in range(n_iter):
        gp.fit(alphas, ys)
        
        # Expected Improvement Acquisition function
        def expected_improvement(x):
            x = np.atleast_2d(x)
            mu, sigma = gp.predict(x, return_std=True)
            sigma = np.maximum(sigma, 1e-9)
            best_y = np.min(ys)
            z = (best_y - mu) / sigma
            ei = (best_y - mu) * norm.cdf(z) + sigma * norm.pdf(z)
            return -ei  # maximize EI (so minimize -EI)
        
        # Optimize Expected Improvement by evaluating log-grid
        candidates = np.logspace(-15, 2, 100).reshape(-1, 1)
        ei_vals = [-expected_improvement(c)[0] for c in candidates]
        next_alpha = candidates[np.argmax(ei_vals)]
        
        next_y = objective(next_alpha)
        alphas = np.vstack((alphas, next_alpha))
        ys = np.append(ys, next_y)
        
        print(f"  Iteration {i+1:02d}: Candidate Alpha = {float(next_alpha):.2e} -> CV RMSE = {next_y:.4f}")
        
    best_idx = np.argmin(ys)
    best_alpha = float(alphas[best_idx])
    best_rmse = ys[best_idx]
    print(f"\nOptimization Complete! Best Alpha = {best_alpha:.2e} (CV RMSE = {best_rmse:.4f})")
    return best_alpha


