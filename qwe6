# 2a. Fix defects - Extract company name from CarName, drop car_ID
df['carCompany'] = df['CarName'].apply(lambda x: x.split()[0].lower())

# Fix misspelled company names
df['carCompany'] = df['carCompany'].replace({
    'maxda':'mazda','porcshce':'porsche','toyouta':'toyota',
    'vokswagen':'volkswagen','vw':'volkswagen'
})

df.drop(['car_ID','CarName'], axis=1, inplace=True)

# Cap outliers using IQR
