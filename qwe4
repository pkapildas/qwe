def grid_search_lasso(X_train, y_train, X_test, y_test):
    """
    Uses GridSearchCV to find the optimal alpha for Lasso regression.
    Reports best alpha and RMSE on test set.
    """
    from sklearn.model_selection import GridSearchCV
    from sklearn.metrics import mean_squared_error

    alphas = np.logspace(-4, 2, 50)  # 50 values from 0.0001 to 100
    param_grid = {'alpha': alphas}

    lasso = Lasso(max_iter=500)
    grid = GridSearchCV(
        estimator=lasso,
        param_grid=param_grid,
        scoring='neg_root_mean_squared_error',
        cv=5,
        return_train_score=True
    )
    grid.fit(X_train, y_train)

    print('=' * 60)
    print('GridSearchCV - Lasso Alpha Tuning')
    print('=' * 60)
    print(f'Best Alpha: {grid.best_params_["alpha"]:.6f}')
    print(f'Best CV RMSE: {-grid.best_score_:.4f}')

    # Evaluate on test set
    best_lasso = grid.best_estimator_
    y_pred = best_lasso.predict(X_test)
    test_rmse = np.sqrt(mean_squared_error(y_test, y_pred))
    print(f'Test RMSE (best alpha): {test_rmse:.4f}')

    # Plot alpha vs CV RMSE
    results = pd.DataFrame(grid.cv_results_)
    plt.figure(figsize=(10, 5))
    plt.semilogx(results['param_alpha'].astype(float),
                 -results['mean_test_score'], marker='o', markersize=3)
    plt.xlabel('Alpha (log scale)')
    plt.ylabel('Mean CV RMSE')
    plt.title('Lasso: Alpha vs CV RMSE (GridSearchCV)')
    plt.axvline(grid.best_params_['alpha'], color='red', linestyle='--',
                label=f'Best alpha = {grid.best_params_["alpha"]:.6f}')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.show()

    return grid

