from sklearn.linear_model import ElasticNet

def compare_ridge_lasso_elasticnet_cv(X_train, y_train, X_test, y_test):
    """
    Compares Ridge, Lasso, and ElasticNet using 5-Fold CV on train data.
    Reports RMSE on both CV (train) and test set. Suggests the best model.
    """
    from sklearn.model_selection import KFold, cross_val_score
    from sklearn.metrics import mean_squared_error
    kf = KFold(n_splits=5, shuffle=True, random_state=42)
    results = {}

    # Ridge
    ridge = Ridge(alpha=1.0, max_iter=500)
    ridge_cv = cross_val_score(ridge, X_train, y_train, cv=kf,
                               scoring='neg_root_mean_squared_error')
    ridge.fit(X_train, y_train)
    ridge_test_rmse = np.sqrt(mean_squared_error(y_test, ridge.predict(X_test)))
    results['Ridge'] = {'CV_RMSE': -ridge_cv.mean(), 'Test_RMSE': ridge_test_rmse}

    # Lasso
    lasso = Lasso(alpha=0.01, max_iter=500)
    lasso_cv = cross_val_score(lasso, X_train, y_train, cv=kf,
                               scoring='neg_root_mean_squared_error')
    lasso.fit(X_train, y_train)
    lasso_test_rmse = np.sqrt(mean_squared_error(y_test, lasso.predict(X_test)))
    results['Lasso'] = {'CV_RMSE': -lasso_cv.mean(), 'Test_RMSE': lasso_test_rmse}

    # ElasticNet
    enet = ElasticNet(alpha=0.1, l1_ratio=0.01, max_iter=500)
    enet_cv = cross_val_score(enet, X_train, y_train, cv=kf,
                              scoring='neg_root_mean_squared_error')
    enet.fit(X_train, y_train)
    enet_test_rmse = np.sqrt(mean_squared_error(y_test, enet.predict(X_test)))
    results['ElasticNet'] = {'CV_RMSE': -enet_cv.mean(), 'Test_RMSE': enet_test_rmse}

    # Print results
    print('=' * 60)
    print('Model Comparison: Ridge vs Lasso vs ElasticNet')
    print('=' * 60)
    res_df = pd.DataFrame(results).T
    print(res_df.to_string())
    best = res_df['Test_RMSE'].idxmin()
    print(f'\nBest Model (lowest Test RMSE): {best} '
          f'(RMSE = {res_df.loc[best, "Test_RMSE"]:.4f})')
    return res_df

