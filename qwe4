# 2. Skewness Check & Treatment
def check_and_fix_skewness(df, threshold=0.75):
    num_cols = df.select_dtypes(include='number').columns
    skewness = df[num_cols].skew()
    print("Skewness Metrics:\n", skewness)
    
    transformed_df = df.copy()
    for col in num_cols:
        if abs(skewness[col]) > threshold:
            min_val = transformed_df[col].min()
            if min_val <= 0:
                transformed_df[col] = np.log1p(transformed_df[col] - min_val)
            else:
                transformed_df[col] = np.log1p(transformed_df[col])
            print(f"  Applied log-transform on '{col}' (skew change: {skewness[col]:.2f} -> {transformed_df[col].skew():.2f})")
    return transformed_df

