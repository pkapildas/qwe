          f'{mean_absolute_error(y_test, y_pred_test):>12.4f}')

    # MAPE (handle division by zero)
    mask = y_test != 0
    mape_test = np.mean(np.abs((y_test[mask] - y_pred_test[mask]) / y_test[mask])) * 100
    mask_tr = y_train != 0
